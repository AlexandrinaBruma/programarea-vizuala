<Window x:Class="WPF_App1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_App1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel>
            <Label Name="label1" Content="Username" Width="125"/>
            <TextBox Name="usernametextbox" TextWrapping="Wrap" Text="TextBox" Width="120"/>
            <Label Name="label2" Content="Password" Width="136"/>
            <TextBox Name="passwordtextbox" TextWrapping="Wrap" Text="TextBox" Width="120"/>
            <Button Name="loginbutton"  Content="Log in" Width="192" Click="loginbutton_Click"/>
        </StackPanel>
    </Grid>
</Window>
